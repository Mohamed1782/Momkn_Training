pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t simplebackendapp:test .'
            }
        }

        stage('Deploy to Minikube') {
            steps {
                sh 'kubectl apply -f jenkins_first_task/k8s/deployment.yaml'
                sh 'kubectl apply -f jenkins_first_task/k8s/service.yaml'
            }
        }
    }
}